# ===== web(Vercel)=====
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://interval.vercel.app

# Resend(email 通知;未設定則靜默停用)
RESEND_API_KEY=
RESEND_FROM=interval <onboarding@resend.dev>
CONTACT_NOTIFY_TO=admin@example.com

# Gemini(AI 客服/報價;未設定則退化為規則式回覆,流程仍可運作)
GEMINI_API_KEY=
# GEMINI_MODEL=gemma-4-31b-it

# PChomePay 支付連(信用卡/ATM/超商代碼;APP_ID/SECRET 都設定才會在結帳頁顯示刷卡選項)
PCHOMEPAY_APP_ID=
PCHOMEPAY_SECRET=
PCHOMEPAY_SANDBOX=false
PCHOMEPAY_PAY_TYPES=CARD
# webhook 密鑰:notify_url 會附上 ?k=<此值>,webhook route 用它擋掉偽造 POST(未設定時
# webhook 一律回 503)。請自行產生一組高熵亂數字串(如 openssl rand -hex 32),不要用
# 短字串或可猜測的值。
PCHOMEPAY_WEBHOOK_SECRET=

# ===== api(Railway)=====
SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=(同上)
# RESEND_API_KEY=(同上)
SITE_URL=https://interval.vercel.app
JOB_SECRET=
QUOTE_FOLLOWUP_DAYS=3
TZ=Asia/Taipei

# ===== 一鍵佈建 scripts/provision.mjs 用 =====
SUPABASE_ACCESS_TOKEN=sbp_xxx
VERCEL_TOKEN=
RAILWAY_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
# SUPABASE_ORG_ID=
# GITHUB_REPO=LaiQuan-tech/interval
# PROJECT_NAME=interval
